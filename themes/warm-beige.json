{
  "name": "Warm Beige",
  "type": "dark",
  "colors": {
    "editor.background": "#1a1614",
    "editor.foreground": "#e8d5c4",
    "activityBar.background": "#0f0d0c",
    "activityBar.foreground": "#d4b899",
    "activityBar.inactiveForeground": "#6b5d52",
    "activityBarBadge.background": "#c4a87e",
    "activityBarBadge.foreground": "#1a1614",
    "sideBar.background": "#151210",
    "sideBar.foreground": "#d4b899",
    "sideBarTitle.foreground": "#e8d5c4",
    "sideBarSectionHeader.background": "#1a1614",
    "sideBarSectionHeader.foreground": "#c4a87e",
    "list.activeSelectionBackground": "#2d2520",
    "list.activeSelectionForeground": "#e8d5c4",
    "list.hoverBackground": "#23201c",
    "list.inactiveSelectionBackground": "#23201c",
    "statusBar.background": "#0f0d0c",
